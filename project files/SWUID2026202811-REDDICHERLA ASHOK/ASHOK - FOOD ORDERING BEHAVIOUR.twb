      <column caption='Zero' datatype='integer' name='[Calculation_0781769765720065]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='Region' datatype='string' name='[Calculation_0781769768054788]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [meal_type] = &quot;Breakfast&quot; THEN &quot;Snacks&quot;&#13;&#10;ELSEIF [meal_type] = &quot;Lunch&quot; THEN &quot;Breakfast&quot;&#13;&#10;ELSEIF [meal_type] = &quot;Snacks&quot; THEN &quot;Dinner&quot;&#13;&#10;ELSEIF [meal_type] = &quot;Dinner&quot; THEN &quot;Lunch&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
