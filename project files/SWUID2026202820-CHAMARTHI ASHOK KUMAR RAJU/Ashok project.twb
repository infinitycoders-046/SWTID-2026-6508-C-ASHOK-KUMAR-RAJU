    <worksheet name='order distribution by age group and restaurant segment'>
      <table>
        <view>
          <datasources>
            <datasource caption='food_ordering_behavior_dataset' name='federated.1rg1i9g186k4eq14832ru0kj04g8' />
          </datasources>
          <datasource-dependencies datasource='federated.1rg1i9g186k4eq14832ru0kj04g8'>
            <column caption='AGE GROUP' datatype='string' name='[Calculation_0486272184717326]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF[age]&lt;=20 THEN &quot;CHILD&quot;&#13;&#10;ELSEIF [age]&gt;=21 AND[age]&lt;=30 THEN &quot;GEN Z&quot;&#13;&#10;ELSEIF [age]&gt;=31 AND[age]&lt;=40 THEN &quot;MILLENNIAL&quot;&#13;&#10;ELSE &quot;ADULTS&quot;&#13;&#10;END' />
            </column>
