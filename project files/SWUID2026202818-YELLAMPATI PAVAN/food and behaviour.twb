      <column caption='zero' datatype='integer' name='[Calculation_1706184246808577]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='Region' datatype='string' name='[Calculation_1706184247914498]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [meal_type] = &quot;Breakfast&quot; THEN &quot;Morning&quot;&#13;&#10;ELSEIF [meal_type] = &quot;Lunch&quot; THEN &quot;Afternoon&quot;&#13;&#10;ELSEIF [meal_type] = &quot;Snacks&quot; THEN &quot;Evening&quot;&#13;&#10;ELSEIF [meal_type] = &quot;Dinner&quot; THEN &quot;Night&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
        <aliases>
          <alias key='&quot;Afternoon&quot;' value='Breakfast' />
          <alias key='&quot;Evening&quot;' value='Dinner' />
          <alias key='&quot;Morning&quot;' value='Lunch' />
          <alias key='&quot;Night&quot;' value='Snacks' />
        </aliases>
      </column>
      <column caption='sales' datatype='integer' name='[Calculation_1706184250056707]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='Age Group' datatype='integer' name='[Calculation_1706184254218246]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='01' />
      </column>
      <column caption='AGE GROUP' datatype='string' name='[Calculation_1706184255340552]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [age]&lt;=20 THEN&quot;child&quot;&#13;&#10;ELSEIF [age]&gt;=21 AND [age]&lt;=30 THEN &quot;GENZ&quot;&#13;&#10;ELSEIF [age]&gt;=31 AND [age]&lt;=40 THEN &quot;MILLENIAL&quot;&#13;&#10;ELSE &quot;ADULT&quot;&#13;&#10;END' />
      </column>
